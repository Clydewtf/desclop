{
  "name": "desclop",
  "private": true,
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "dev": "npm --workspace apps/desktop run dev",
    "test": "npm --workspace apps/desktop run test",
    "test:e2e": "npm --workspace apps/desktop run test:e2e",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets",
    "lint:rust": "cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "format:check": "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --all -- --check",
    "tauri": "npm --workspace apps/desktop run tauri"
  }
}
